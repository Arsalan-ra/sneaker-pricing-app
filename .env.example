# Copy this file to .env for local development and fill in real values.
# Never commit the real .env file.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model tier: "quality" (Sonnet 4.6, best accuracy, ~5x cost) or "economy"
# (Haiku 4.5, cheaper, still solid for this task). Good one to flip to "economy"
# for a public/recruiter-facing demo where cost matters more than squeezing out
# the last bit of accuracy. Leave unset to default to "quality".
CLAUDE_MODEL_TIER=quality

# Advanced: set this directly to use a specific model string instead of a tier.
# Overrides CLAUDE_MODEL_TIER if set.
# CLAUDE_MODEL=claude-sonnet-4-6

# EBAY_ENV controls comp data source: mock | sandbox | production
EBAY_ENV=mock
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
