# On Streamlit Community Cloud, set these under App Settings -> Secrets
# (paste this format there, with real values). Do not commit real secrets.

ANTHROPIC_API_KEY = "sk-ant-your-key-here"

# "quality" (Sonnet 4.6) or "economy" (Haiku 4.5) -- flip to "economy" to cut
# per-analysis cost roughly 5x for a public/recruiter-facing demo.
CLAUDE_MODEL_TIER = "quality"

EBAY_ENV = "mock"
EBAY_CLIENT_ID = "your-ebay-client-id"
EBAY_CLIENT_SECRET = "your-ebay-client-secret"
